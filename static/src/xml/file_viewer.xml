<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.FileViewer" t-inherit-mode="extension">
        <xpath expr="." position="inside">
            <div t-ref="officePreviewContainer"
                 class="o_office_viewer_layer"
                 style="position: fixed; inset: 0; z-index: 99999; display: flex; flex-direction: column; pointer-events: none;">
                 </div>
        </xpath>
    </t>
    <t t-inherit="documents.FileViewer" t-inherit-mode="extension">
        <xpath expr="." position="inside">
            <div t-ref="officePreviewContainer"
                 class="o_office_viewer_layer"
                 style="position: fixed; inset: 0; z-index: 99999; display: flex; flex-direction: column; pointer-events: none;">
            </div>
        </xpath>
    </t>
</templates>